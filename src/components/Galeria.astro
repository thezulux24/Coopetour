---
---
<section id="galeria" class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="mb-16">
      <h2 class="text-4xl md:text-5xl font-extrabold text-[#0F172A] tracking-tight">Apoya y Descubre</h2>
      <p class="text-lg text-slate-600 mt-4 max-w-2xl">
        Un recorrido visual por nuestra realidad, el ecosistema que protegemos y los productos que financian nuestra recuperación.
      </p>
    </div>

    <!-- Bento Gallery -> Museum Gallery from Stitch -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-start">
      
      <!-- Large Feature -->
      <figure class="md:col-span-8 flex flex-col gap-4">
        <img alt="Visión del ecoparque" class="w-full h-auto object-cover" src="/images/vista2Render.jpeg"/>
        <figcaption class="text-[11px] font-bold uppercase tracking-widest text-slate-500 border-t border-slate-200 pt-3 flex justify-between">
          <span>Visión Arquitectónica</span>
          <span class="opacity-50">Proyección</span>
        </figcaption>
      </figure>

      <!-- Small Item 1 -->
      <figure class="md:col-span-4 flex flex-col gap-4 md:mt-24">
        <img alt="Naturaleza y Mangle" class="w-full h-auto object-cover grayscale hover:grayscale-0 transition-all duration-700" src="/images/lagoHojaFoto.jpeg"/>
        <figcaption class="text-[11px] font-bold uppercase tracking-widest text-slate-500 border-t border-slate-200 pt-3">
          Ecosistema Natural
        </figcaption>
      </figure>

      <!-- Small Item 2 -->
      <figure class="md:col-span-4 flex flex-col gap-4">
        <img alt="Personas de la comunidad" class="w-full h-auto object-cover grayscale hover:grayscale-0 transition-all duration-700" src="/images/personas.jpeg"/>
        <figcaption class="text-[11px] font-bold uppercase tracking-widest text-slate-500 border-t border-slate-200 pt-3">
          Comunidad en Acción
        </figcaption>
      </figure>

      <!-- Small Item 3 -->
      <figure class="md:col-span-4 flex flex-col gap-4">
        <img alt="Río San Pedro" class="w-full h-auto object-cover grayscale hover:grayscale-0 transition-all duration-700" src="/images/lago.jpeg"/>
        <figcaption class="text-[11px] font-bold uppercase tracking-widest text-slate-500 border-t border-slate-200 pt-3">
          Río San Pedro Mártir
        </figcaption>
      </figure>

      <!-- Small Item 4 (Merch) -->
      <figure class="md:col-span-4 flex flex-col gap-4 md:mt-12 bg-slate-50 p-8 items-center justify-center">
        <img alt="Jersey Oficial Coopetour" class="max-h-64 object-contain mix-blend-multiply hover:scale-105 transition-transform duration-500" src="/images/presentacionCamisteta.jpeg"/>
        <figcaption class="text-[11px] font-bold uppercase tracking-widest text-slate-500 w-full border-t border-slate-200 pt-3 mt-4 text-center">
          Jersey Oficial - ¡Apóyanos!
        </figcaption>
      </figure>

    </div>

    <div class="mt-20 text-center">
      <a href="#contacto" class="inline-flex items-center gap-2 text-[#FF6600] font-bold hover:text-[#e65c00] transition-colors text-lg">
        Contactar para adquirir merchandising
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

  </div>
</section>
