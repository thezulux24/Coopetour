---
<section id="ubicacion" class="py-24 md:py-32 px-4 sm:px-6 lg:px-12 max-w-7xl mx-auto border-t border-slate-200 mt-16 animate-on-scroll">
  <div class="flex flex-col md:flex-row gap-16">
    
    <div class="w-full md:w-1/3 flex flex-col justify-start">
      <h2 class="font-outfit text-[28px] font-normal text-slate-900 mb-10 leading-[1.4]">Encuéntranos</h2>
      
      <div class="flex flex-col gap-8">
        
        <div class="flex items-start gap-6 border-b border-slate-200 pb-6">
          <span class="material-symbols-outlined text-slate-400 mt-1 text-xl">location_on</span>
          <div>
            <h4 class="font-inter text-[12px] font-medium uppercase tracking-[0.1em] text-slate-900 mb-2">Ubicación</h4>
            <p class="font-inter text-[15px] font-light text-slate-600 leading-[1.7]">
              La Palma, 86912<br/>Tabasco, México
            </p>
          </div>
        </div>

        <div class="flex items-start gap-6 border-b border-slate-200 pb-6">
          <span class="material-symbols-outlined text-slate-400 mt-1 text-xl">mail</span>
          <div id="contacto">
            <h4 class="font-inter text-[12px] font-medium uppercase tracking-[0.1em] text-slate-900 mb-2">Contacto</h4>
            <p class="font-inter text-[15px] font-light text-slate-600 leading-[1.7]">contacto@coopetour.com</p>
          </div>
        </div>

      </div>
    </div>

    <div class="w-full md:w-2/3 h-80 bg-slate-50 relative overflow-hidden rounded-sm">
      <div class="absolute inset-0 bg-slate-200 flex items-center justify-center">
        <span class="material-symbols-outlined text-slate-300 text-4xl">map</span>
      </div>
      <!-- Iframe Google Maps -->
      <iframe 
        class="absolute inset-0 w-full h-full border-0" 
        loading="lazy" 
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d15214.375253896582!2d-91.439818!3d17.574676!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x85ee4bf58d24ba17%3A0x63359d7b420042a9!2s86912%20La%20Palma%2C%20Tab.!5e0!3m2!1ses-419!2smx!4v1700000000000!5m2!1ses-419!2smx" 
        title="Google Maps">
      </iframe>
    </div>

  </div>
</section>
