---
const currentYear = new Date().getFullYear();
---

<footer class="bg-white border-t border-slate-200 w-full relative">
  <div class="relative flex flex-col md:flex-row justify-between items-center px-4 sm:px-6 lg:px-12 py-16 max-w-7xl mx-auto text-center md:text-left gap-10">
    
    <div class="flex flex-col md:flex-row items-center gap-6">
      <!-- Circular Alternate Logo -->
      <img src="/images/logoAlt1.jpg" alt="Coopetour Sello" class="w-16 h-16 rounded-full object-cover shadow-sm border border-slate-100 grayscale hover:grayscale-0 transition-all duration-500" />
      
      <div class="flex flex-col gap-2">
        <span class="font-outfit text-xl text-slate-900 tracking-tight font-medium">Coopetour</span>
        <p class="text-slate-500 font-inter text-xs font-light">
          © {currentYear} Coopetour Ecoturismo La Palma.<br class="hidden md:block" /> Todos los derechos reservados.
        </p>
      </div>
    </div>

    <div class="flex flex-wrap justify-center md:justify-end gap-10">
      <a class="text-slate-600 hover:text-slate-900 transition-colors font-inter text-[12px] font-medium uppercase tracking-[0.1em]" href="/privacidad">Privacidad</a>
      <a class="text-slate-600 hover:text-slate-900 transition-colors font-inter text-[12px] font-medium uppercase tracking-[0.1em]" href="/terminos">Términos</a>
      <a class="text-slate-600 hover:text-slate-900 transition-colors font-inter text-[12px] font-medium uppercase tracking-[0.1em]" href="/#galeria">Galería</a>
      <a class="text-slate-600 hover:text-slate-900 transition-colors font-inter text-[12px] font-medium uppercase tracking-[0.1em]" href="/#contacto">Contacto</a>
    </div>

  </div>
</footer>
