---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Experiencias from '../components/Experiencias.astro';
import Contexto from '../components/Contexto.astro';
import Pilares from '../components/Pilares.astro';
import ImpactoComunidad from '../components/ImpactoComunidad.astro';
import NumerosImpacto from '../components/NumerosImpacto.astro';
import Galeria from '../components/Galeria.astro';
import FAQ from '../components/FAQ.astro';
import LocationMap from '../components/LocationMap.astro';
import WhatsAppWidget from '../components/WhatsAppWidget.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Coopetour Ecoturismo La Palma | Reactivación Turística">
